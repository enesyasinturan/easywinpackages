<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.softeyt.easywinpackages.view.uninstall.UninstallController"
      VBox.vgrow="ALWAYS">

    <VBox styleClass="screen-header">
        <HBox alignment="CENTER_LEFT" spacing="12">
            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label fx:id="lblTitle"    styleClass="screen-title"/>
                <Label fx:id="lblSubtitle" styleClass="screen-subtitle"/>
            </VBox>
            <ComboBox fx:id="cmbSource" prefWidth="160"/>
            <Button fx:id="btnRefresh" styleClass="btn-secondary" onAction="#onRefresh"/>
        </HBox>
    </VBox>

    <VBox style="-fx-padding: 10 28 10 28;" spacing="6">
        <ProgressBar fx:id="progressBar" maxWidth="Infinity" visible="false" managed="false"/>
        <Label fx:id="lblStatus" styleClass="muted-label"/>
    </VBox>

    <VBox VBox.vgrow="ALWAYS" style="-fx-padding: 0 28 24 28;">
        <TableView fx:id="tblInstalled" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colName"    minWidth="160" prefWidth="220"/>
                <TableColumn fx:id="colId"      minWidth="140" prefWidth="200"/>
                <TableColumn fx:id="colVersion" minWidth="80"  prefWidth="110"/>
                <TableColumn fx:id="colSource"  minWidth="80"  prefWidth="100"/>
                <TableColumn fx:id="colAction"  minWidth="110" prefWidth="120" maxWidth="130"/>
            </columns>
            <placeholder><Label fx:id="lblNoPackages" styleClass="muted-label"/></placeholder>
        </TableView>
    </VBox>
</VBox>

